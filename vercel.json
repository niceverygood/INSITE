{
  "buildCommand": "cd frontend && npm install && npm run build && cp -r dist/. ../public/",
  "functions": {
    "api/**/*.py": {
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...path].py" },
    { "src": "/health", "dest": "/api/[...path].py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
