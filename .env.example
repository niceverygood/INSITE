# ========== Application ==========
APP_NAME=INSITE
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7

# ========== PostgreSQL ==========
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=insite
POSTGRES_USER=insite
POSTGRES_PASSWORD=insite_password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ========== TimescaleDB ==========
TIMESCALE_HOST=timescaledb
TIMESCALE_PORT=5433
TIMESCALE_DB=insite_metrics
TIMESCALE_USER=insite
TIMESCALE_PASSWORD=insite_password
TIMESCALE_URL=postgresql+asyncpg://${TIMESCALE_USER}:${TIMESCALE_PASSWORD}@${TIMESCALE_HOST}:${TIMESCALE_PORT}/${TIMESCALE_DB}

# ========== Redis ==========
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ========== Kafka ==========
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID=insite-backend

# ========== Elasticsearch ==========
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_URL=http://${ELASTICSEARCH_HOST}:${ELASTICSEARCH_PORT}

# ========== Prometheus ==========
PROMETHEUS_URL=http://prometheus:9090

# ========== AI / LLM ==========
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER=openai
AI_MODEL=gpt-4o

# ========== Email (SMTP) ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@insite.local

# ========== Slack ==========
SLACK_WEBHOOK_URL=

# ========== Kakao ==========
KAKAO_API_KEY=
KAKAO_SENDER_KEY=

# ========== SMS ==========
SMS_API_URL=
SMS_API_KEY=

# ========== Report ==========
REPORT_OUTPUT_DIR=/app/reports
REPORT_EMAIL_RECIPIENTS=

# ========== SNMP ==========
SNMP_COMMUNITY=public
SNMP_TIMEOUT=5
SNMP_RETRIES=3

# ========== Frontend ==========
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
